# Profile Template
# Copy to ~/.config/parsemedicalexams/{your_name}.yaml

name: "your_name"

# Required: Paths to input/output directories
input_path: "/path/to/your/exam/pdfs"
output_path: "/path/to/your/output"

# Optional: Filter which PDFs to process (default: .*\.pdf)
input_file_regex: ".*\\.pdf"

# Shared API key and model IDs live in ~/.config/parsemedicalexams/.env
# You can still override them here if needed:
# model: "google/gemini-2.5-flash"
# extract_model_id: "google/gemini-2.5-flash"
# summarize_model_id: "google/gemini-2.5-flash"
# self_consistency_model_id: "google/gemini-2.5-flash"
# validation_model_id: "anthropic/claude-haiku-4.5"
# openrouter_api_key: "override_api_key"
# openrouter_base_url: "https://openrouter.ai/api/v1"

# Optional runtime config:
# n_extractions: 3
# workers: 4
# summarize_max_input_tokens: 100000

# Optional patient context
full_name: "Your Full Name"
birth_date: "YYYY-MM-DD"
locale: "pt-PT"
